@baseUrl = http://localhost:3000
@contentType = application/json

# Replace after login; path tenant must match JWT tenantId (unless super_admin).
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOjQzLCJyb2xlIjoic3VwZXJfYWRtaW4iLCJ0ZW5hbnRJZCI6bnVsbCwiaWF0IjoxNzc1MzAxMzc4LCJleHAiOjE3NzUzMDQ5Nzh9.6E3q4QeA0Xh7zzKhC0AxzvynRAQO0qSZn21AkKlzB8I

@tenantId = 9
@serviceId = 6
@specialistId = 8
### List services for tenant
GET {{baseUrl}}/tenants/{{tenantId}}/services
Authorization: Bearer {{accessToken}}

### Create service
POST {{baseUrl}}/tenants/{{tenantId}}/services
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Initial consultation",
  "duration": 30,
  "price": "49.99"
}

### Get service by id
GET {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}
Authorization: Bearer {{accessToken}}

### Assign specialist to service (same tenant)
POST {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}/specialists
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "specialistId": {{specialistId}}
}

### Unassign specialist from service
DELETE {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}/specialists/{{specialistId}}
Authorization: Bearer {{accessToken}}

### Update service
PUT {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Initial consultation (extended)",
  "duration": 45,
  "price": "59.99"
}

### Update service (partial — only price)
PUT {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "price": "54.99"
}

### Delete service
DELETE {{baseUrl}}/tenants/{{tenantId}}/services/{{serviceId}}
Authorization: Bearer {{accessToken}}
